# FFRAG Environment Variables Template
# Copy this to .env and fill in your actual API keys
# DO NOT COMMIT .env to version control

# ─────────────────────────────────────────────────────────────
# API KEYS (Required - Get from services below)
# ─────────────────────────────────────────────────────────────

# Groq API Key - https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Replicate API Token (optional, for future vision models)
REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE

# HuggingFace User Access Token (optional, for private models)
# https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE

# ─────────────────────────────────────────────────────────────
# NEO4J AURADB (Required for graph queries)
# ─────────────────────────────────────────────────────────────

# Get from https://console.neo4j.io → your instance → Connection details
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# ─────────────────────────────────────────────────────────────
# LLM & EMBEDDING MODELS
# ─────────────────────────────────────────────────────────────

# Generation LLM (via Groq)
LLM_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.1

# Embedding model (HuggingFace)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranking model (HuggingFace)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─────────────────────────────────────────────────────────────
# OLLAMA (Local LLM - Optional)
# ─────────────────────────────────────────────────────────────

# For graph captioning (LLaVA) or local judge evaluation (Qwen2.5)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llava:7b
OLLAMA_TIMEOUT=600

# ─────────────────────────────────────────────────────────────
# RETRIEVAL SETTINGS
# ─────────────────────────────────────────────────────────────

# ChromaDB (vector storage)
CHROMA_DIR=chroma_db

# Retrieval hyperparameters
TOP_K_EACH=10        # per retriever per collection
TOP_K_RERANK=5       # final chunks to LLM

# ─────────────────────────────────────────────────────────────
# DATA PATHS
# ─────────────────────────────────────────────────────────────

TRANSACTIONS_FILE=DATA/transactions/saml_synthetic_1000.csv
CAPTIONS_FILE=DATA/graph_captions.json
GRAPHS_DIR=DATA/graphs
METADATA_FILE=DATA/graphs/graph_metadata.json
REGULATIONS_DIR=DATA/regulations

# ─────────────────────────────────────────────────────────────
# EVALUATION SETTINGS
# ─────────────────────────────────────────────────────────────

RESULTS_FILE=evaluation/ragas_results.json
METRICS_FILE=evaluation/retrieval_metrics.json
